fn demo_edge_cases() -> void {
    print(StringUtils::make_header("Edge Cases"));

    // Empty loop with immediate break
    mut i: int32 = 0;
    while true {
        if i >= 5 {
            break;
        }
        i = i + 1;
    }
    print(i);

    // continue skips multiples of 3
    mut count: int32 = 0;
    mut j: int32 = 0;
    while j < 12 {
        j = j + 1;
        if j % 3 == 0 {
            continue;
        }
        count = count + 1;
    }
    print(count);

    // Multiple assignments to same variable
    mut x: int32 = 1;
    x = x + 1;
    x = x * 3;
    x = x - 2;
    print(x);

    // Complex nested boolean expressions
    let a: bool = true;
    let b: bool = false;
    let c: bool = true;
    if (a || b) && (c || b) {
        print("complex and");
    }
    if !(a && b) || c {
        print("not and or c");
    }
    if !b && !b && a {
        print("triple bool");
    }

    // Float edge values
    let zero_f: float64 = 0.0;
    let one_f: float64  = 1.0;
    let neg_f: float64  = 0.0 - 1.0;
    let small_f: float64 = 0.000001;
    let large_f: float64 = 999999.99;
    print(zero_f);
    print(one_f);
    print(neg_f);
    print(small_f);
    print(large_f);
    print(abs_f64(neg_f));

    // Array element assignments via expressions
    mut arr: [8]int32 = [0, 0, 0, 0, 0, 0, 0, 0];
    mut k: int32 = 0;
    while k < 8 {
        arr[k] = k * k;
        k = k + 1;
    }
    print(arr[0]);
    print(arr[3]);
    print(arr[7]);

    // Deeply nested function calls
    print(abs_i32(sign_i32(0 - 15)));
    print(clamp_i32(abs_i32(0 - 20), 5, 15));
    print(power_i32(gcd(12, 8), 3));
    print(max_of_three(abs_i32(0 - 3), gcd(10, 4), sign_i32(100)));

    // String edge cases
    let a_s: string = "";
    print(len(a_s));
    let b_s: string = a_s + "hello";
    print(b_s);
    let c_s: string = b_s + " " + "world";
    print(len(c_s));

    // Large literal values
    let big_i64: int64 = 1000000000000i64;
    let big_u64: uint64 = 9999999999u64;
    let tiny_f32: float32 = 0.0001f32;
    let big_f64: float64  = 123.456789;
    print(big_i64);
    print(big_u64);
    print(tiny_f32);
    print(big_f64);

    // Literal suffixes comprehensive
    let li8:  int8   = 42i8;
    let li16: int16  = 1000i16;
    let li32: int32  = 100000i32;
    let li64: int64  = 10000000i64;
    let lu8:  uint8  = 200u8;
    let lu16: uint16 = 50000u16;
    let lu32: uint32 = 2000000u32;
    let lu64: uint64 = 5000000u64;
    let lf32: float32 = 3.14f32;
    let lf64: float64 = 2.718f64;
    print(li8);
    print(li16);
    print(li32);
    print(li64);
    print(lu8);
    print(lu16);
    print(lu32);
    print(lu64);
    print(lf32);
    print(lf64);
}

