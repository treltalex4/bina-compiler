    demo_arrays();
    demo_control_flow();
    demo_math();
    demo_geometry();
    demo_physics();
    demo_matrix();
    demo_colors();
    demo_structs_and_impl();
    demo_type_aliases();
    demo_sorting();
    demo_edge_cases();

    print("=== All demos completed ===");
    return 0;
}
